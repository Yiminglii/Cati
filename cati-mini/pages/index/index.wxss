/* ============================================================
   🐱 Cati 小程序 - 页面样式
   ============================================================ */

/* ---------- 装饰emoji ---------- */
.floating-decors { position: fixed; pointer-events: none; z-index: 0; }
.fdec { position: absolute; font-size: 40rpx; opacity: 0.12; animation: fFloat 7s ease-in-out infinite; }
.d1 { top: 8%; left: 4%; font-size: 50rpx; }
.d2 { top: 18%; right: 6%; animation-delay: 1s; }
.d3 { top: 55%; left: 3%; animation-delay: 2s; font-size: 36rpx; }
.d4 { top: 70%; right: 4%; animation-delay: 3s; font-size: 44rpx; }
.d5 { top: 38%; left: 7%; animation-delay: 4s; font-size: 30rpx; }
.d6 { bottom: 12%; right: 10%; animation-delay: 1.5s; }

@keyframes fFloat {
  0%, 100% { transform: translateY(0) rotate(0); }
  50% { transform: translateY(-20rpx) rotate(10deg); }
}

/* ---------- 首页 ---------- */
.home-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 80rpx;
  min-height: 100vh;
}
.logo-area { margin-bottom: 48rpx; animation: bIn .8s ease; }
.logo-cat {
  font-size: 152rpx;
  line-height: 1;
  filter: drop-shadow(0 8rpx 24rpx rgba(255,107,157,.3));
  animation: cWiggle 2.5s ease-in-out infinite;
}

@keyframes cWiggle {
  0%, 100% { transform: rotate(-3deg); }
  50% { transform: rotate(3deg); }
}
@keyframes bIn {
  0% { transform: scale(0); opacity: 0; }
  50% { transform: scale(1.15); }
  100% { transform: scale(1); opacity: 1; }
}

.title {
  font-size: 56rpx;
  font-weight: 900;
  background: linear-gradient(135deg, #FF6B9D, #FF8C42, #9B7EDE);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 12rpx;
  letter-spacing: 4rpx;
}
.subtitle {
  font-size: 28rpx;
  color: #7A6555;
  margin-bottom: 64rpx;
  font-weight: 600;
  line-height: 1.8;
  text-align: center;
  white-space: pre-line;
}

.start-btn {
  background: linear-gradient(135deg, #FF6B9D, #FF8C42);
  color: white;
  border: none;
  padding: 34rpx 104rpx;
  font-size: 36rpx;
  font-weight: 800;
  border-radius: 100rpx;
  box-shadow: 0 16rpx 56rpx rgba(255,107,157,.35);
  letter-spacing: 4rpx;
  overflow: hidden;
  position: relative;
  line-height: 1.2;
}
.start-btn::after {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: linear-gradient(transparent, rgba(255,255,255,.2), transparent);
  transform: rotate(45deg);
  animation: sShine 3s infinite;
}
@keyframes sShine {
  0% { transform: translateX(-100%) rotate(45deg); }
  100% { transform: translateX(100%) rotate(45deg); }
}

.home-tags {
  display: flex;
  gap: 20rpx;
  flex-wrap: wrap;
  justify-content: center;
  margin-top: 56rpx;
}
.tag {
  background: rgba(255,255,255,.7);
  backdrop-filter: blur(20rpx);
  padding: 12rpx 32rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #7A6555;
  font-weight: 600;
}

/* ---------- MBTI输入页 ---------- */
.input-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  padding-top: 60rpx;
  min-height: 100vh;
}
.input-card {
  background: rgba(255,255,255,.88);
  backdrop-filter: blur(40rpx);
  border-radius: 56rpx;
  padding: 72rpx 56rpx;
  box-shadow: 0 24rpx 88rpx rgba(255,107,157,.16);
  width: calc(100% - 80rpx);
  border: 4rpx solid rgba(255,255,255,.6);
}
.input-title {
  font-size: 36rpx;
  font-weight: 900;
  color: #4A3728;
  margin-bottom: 12rpx;
  display: block;
}
.input-sub {
  font-size: 26rpx;
  color: #7A6555;
  margin-bottom: 56rpx;
  font-weight: 600;
  display: block;
}
.dim-group { margin-bottom: 32rpx; }
.dim-label {
  display: block;
  text-align: center;
  font-size: 26rpx;
  font-weight: 800;
  color: #FF6B9D;
  margin-bottom: 16rpx;
  letter-spacing: 2rpx;
}
.dim-row {
  display: flex;
  gap: 20rpx;
  justify-content: center;
}
.dim-btn {
  flex: 1;
  padding: 28rpx 16rpx;
  border-radius: 28rpx;
  border: 4rpx solid #EEE5E5;
  background: #FAFAFA;
  text-align: center;
  transition: all .25s;
}
.dim-btn text {
  font-size: 30rpx;
  font-weight: 800;
  color: #4A3728;
}
.dim-btn.selected {
  border-color: #FF6B9D;
  background: linear-gradient(135deg, #FF6B9D, #DDA0DD);
  box-shadow: 0 8rpx 32rpx rgba(255,107,157,.3);
  transform: scale(1.04);
}
.dim-btn.selected text { color: white; }

.mbti-preview {
  margin: 48rpx 0 40rpx;
  font-size: 52rpx;
  font-weight: 900;
  background: linear-gradient(135deg, #FF6B9D, #9B7EDE);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  letter-spacing: 12rpx;
  min-height: 84rpx;
  display: block;
  text-align: center;
}
.confirm-btn {
  background: linear-gradient(135deg, #A8E6CF, #87CEEB);
  color: white;
  border: none;
  padding: 30rpx 96rpx;
  font-size: 32rpx;
  font-weight: 800;
  border-radius: 100rpx;
  box-shadow: 0 12rpx 40rpx rgba(168,230,207,.4);
  letter-spacing: 2rpx;
  width: 100%;
}
.confirm-btn[disabled] {
  opacity: .4;
}

/* ---------- 答题页 ---------- */
.quiz-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  padding-top: 56rpx;
  min-height: 100vh;
}
.progress-bar {
  width: 100%;
  height: 20rpx;
  background: rgba(255,255,255,.5);
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 44rpx;
  box-shadow: inset 0 4rpx 8rpx rgba(0,0,0,.05);
}
.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #FF6B9D, #DDA0DD);
  border-radius: 20rpx;
  transition: width .5s cubic-bezier(.34, 1.56, .64, 1);
  position: relative;
}
.progress-fill::after {
  content: '';
  position: absolute;
  right: 0;
  top: 0;
  width: 32rpx;
  height: 100%;
  background: white;
  border-radius: 50%;
  opacity: .6;
  transform: translateX(50%);
}
.progress-text {
  text-align: center;
  font-weight: 700;
  font-size: 26rpx;
  color: #7A6555;
  margin-bottom: 32rpx;
  display: block;
}
.question-card {
  background: rgba(255,255,255,.85);
  backdrop-filter: blur(40rpx);
  border-radius: 48rpx;
  padding: 60rpx 48rpx;
  box-shadow: 0 16rpx 64rpx rgba(255,107,157,.12);
  width: calc(100% - 64rpx);
  border: 4rpx solid rgba(255,255,255,.6);
  animation: sUp .5s ease;
}
@keyframes sUp {
  from { opacity: 0; transform: translateY(60rpx); }
  to { opacity: 1; transform: translateY(0); }
}
.q-icon {
  font-size: 80rpx;
  text-align: center;
  margin-bottom: 24rpx;
  display: block;
}
.q-num {
  font-size: 24rpx;
  font-weight: 700;
  color: #FF6B9D;
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
  display: block;
  text-align: center;
}
.q-tag {
  display: inline-block;
  background: linear-gradient(135deg, rgba(255,107,157,.14), rgba(155,126,222,.14));
  padding: 8rpx 28rpx;
  border-radius: 24rpx;
  margin-bottom: 16rpx;
}
.q-tag text {
  font-size: 24rpx;
  font-weight: 700;
  color: #FF6B9D;
  letter-spacing: 1rpx;
}
.q-text {
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.6;
  text-align: center;
  margin-bottom: 48rpx;
  color: #4A3728;
  display: block;
}
.options {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}
.option {
  background: linear-gradient(135deg, #FAFAFA, #F5F0F0);
  border: 4rpx solid #EEE5E5;
  border-radius: 32rpx;
  padding: 30rpx 40rpx;
  display: flex;
  align-items: center;
  gap: 26rpx;
  font-weight: 700;
  transition: all .3s;
}
.option:active {
  transform: scale(.97);
  background: linear-gradient(135deg, #FFF5F8, #FFE8EE);
  border-color: #FF6B9D;
}
.opt-icon {
  font-size: 44rpx;
  min-width: 68rpx;
  text-align: center;
}
.opt-letter {
  background: linear-gradient(135deg, #FF6B9D, #DDA0DD);
  color: white;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.opt-letter text {
  font-size: 26rpx;
  font-weight: 800;
  color: white;
}
.opt-text {
  font-size: 28rpx;
  color: #4A3728;
  flex: 1;
  line-height: 1.4;
}

/* ---------- 结果页 ---------- */
.result-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  padding-top: 52rpx;
  min-height: 100vh;
}
.result-card {
  background: rgba(255,255,255,.9);
  backdrop-filter: blur(40rpx);
  border-radius: 56rpx;
  padding: 68rpx 48rpx;
  box-shadow: 0 24rpx 88rpx rgba(255,107,107,.18);
  animation: pIn .7s cubic-bezier(.34, 1.56, .64, 1);
  border: 4rpx solid rgba(255,255,255,.6);
  width: calc(100% - 64rpx);
}
@keyframes pIn {
  from { opacity: 0; transform: scale(.7); }
  to { opacity: 1; transform: scale(1); }
}
.result-badge {
  display: inline-block;
  background: linear-gradient(135deg, #FF6B9D, #DDA0DD);
  color: white;
  padding: 10rpx 36rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  font-weight: 700;
  margin-bottom: 28rpx;
  letter-spacing: 2rpx;
}
.result-badge text { color: white; }

.match-header {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  margin: 32rpx 0 16rpx;
}
.match-type {
  font-size: 48rpx;
  font-weight: 900;
  background: linear-gradient(135deg, #FF6B9D, #9B7EDE);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  letter-spacing: 4rpx;
}
.match-x {
  font-size: 44rpx;
  color: #FFB5A7;
  font-weight: 900;
}

.match-score-circle {
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  margin: 32rpx auto;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  background: linear-gradient(135deg, rgba(255,107,157,.1), rgba(168,230,207,.1));
  border: 6rpx solid #FF6B9D;
}
.match-score-num {
  font-size: 56rpx;
  font-weight: 900;
  color: #FF6B9D;
  line-height: 1;
}
.match-score-label {
  font-size: 24rpx;
  font-weight: 700;
  color: #7A6555;
  letter-spacing: 2rpx;
}

.match-level {
  font-size: 32rpx;
  font-weight: 900;
  margin: 12rpx 0 28rpx;
  display: block;
  text-align: center;
}

.result-cat-img {
  font-size: 128rpx;
  margin: 20rpx 0;
  display: block;
  animation: cWiggle 2.5s ease-in-out infinite;
  filter: drop-shadow(0 8rpx 28rpx rgba(0,0,0,.08));
  text-align: center;
}
.result-name {
  font-size: 36rpx;
  font-weight: 900;
  margin-bottom: 8rpx;
  color: #4A3728;
  display: block;
}
.result-slogan {
  font-size: 28rpx;
  color: #FF6B9D;
  font-weight: 700;
  margin-bottom: 28rpx;
  font-style: italic;
  display: block;
}

.result-desc {
  font-size: 28rpx;
  line-height: 1.84;
  color: #7A6555;
  text-align: left;
  background: linear-gradient(135deg, #FFF9FB, #FDF2F7);
  padding: 32rpx 36rpx;
  border-radius: 32rpx;
  margin: 28rpx 0;
  font-weight: 600;
}
.match-desc {
  font-size: 28rpx;
  line-height: 1.78;
  color: #7A6555;
  text-align: left;
  background: linear-gradient(135deg, #F0FAFF, #EDF5FF);
  padding: 32rpx 36rpx;
  border-radius: 32rpx;
  margin: 28rpx 0;
  font-weight: 600;
  border-left: 8rpx solid #87CEEB;
}
.md-title {
  font-weight: 800;
  color: #4A3728;
}

.result-traits {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  justify-content: center;
  margin: 28rpx 0;
}
.trait-tag {
  background: linear-gradient(135deg, rgba(255,107,157,.12), rgba(155,126,222,.12));
  padding: 10rpx 26rpx;
  border-radius: 24rpx;
}
.trait-tag text {
  font-size: 26rpx;
  font-weight: 700;
  color: #4A3728;
}

.result-dimensions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin: 32rpx 0;
}
.dim-item {
  background: #FAFAFA;
  padding: 18rpx 24rpx;
  border-radius: 24rpx;
}
.dim-lbl {
  display: block;
  color: #7A6555;
  font-size: 24rpx;
  font-weight: 600;
}
.dim-val {
  display: block;
  color: #FF6B9D;
  font-size: 28rpx;
  font-weight: 800;
  margin-top: 4rpx;
}

.action-btns {
  display: flex;
  gap: 22rpx;
  margin-top: 40rpx;
  flex-wrap: wrap;
  justify-content: center;
}
.action-btn {
  padding: 24rpx 56rpx;
  border-radius: 100rpx;
  font-weight: 800;
  font-size: 28rpx;
  border: none;
  letter-spacing: 2rpx;
  color: white;
  line-height: 1.2;
}
.btn-retest {
  background: linear-gradient(135deg, #A8E6CF, #87CEEB);
  box-shadow: 0 12rpx 40rpx rgba(168,230,207,.4);
}
.btn-share {
  background: linear-gradient(135deg, #FF6B9D, #FF8C42);
  box-shadow: 0 12rpx 40rpx rgba(255,107,157,.4);
}
